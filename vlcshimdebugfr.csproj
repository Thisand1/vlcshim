<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows10.0.26100.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.26100.0</SupportedOSPlatformVersion>
    <UseWindowsForms>true</UseWindowsForms>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <EnableCsWinRT>true</EnableCsWinRT>
    <ApplicationIcon>assets\vlc.ico</ApplicationIcon>
    <AssemblyTitle>VLC</AssemblyTitle>
    <Product>VLC</Product>
    <Description>VLC bridge</Description>
    <Company>VideoLAN</Company>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CsWinRT" Version="2.2.0" />
    <PackageReference Include="Vortice.Direct2D1" Version="3.8.2" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="assets\vlc.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
